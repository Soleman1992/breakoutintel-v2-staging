# ─── BreakoutIntel — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in all values before running docker-compose up

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
DOMAIN=breakoutintel.yourdomain.com
SSL_EMAIL=your@email.com

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://breakoutintel.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://breakoutintel.yourdomain.com
NEXT_PUBLIC_APP_NAME=BreakoutIntel
CORS_ORIGIN=https://breakoutintel.yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=breakoutintel
POSTGRES_USER=biuser
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32CHARS
DATABASE_URL=postgresql://biuser:CHANGE_THIS_STRONG_PASSWORD_32CHARS@postgres:5432/breakoutintel

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_USE_openssl_rand_hex_32

# ── Holdings Module Auth (/holdings-intel/*) ─────────────────────────────────
# Signing secret for the Holdings module's JWTs. Read from the environment ONLY —
# the code has no default and no fallback. If this is absent or shorter than 32
# chars, the Holdings routes refuse to mount (the rest of the app is unaffected).
#
# Generate:  openssl rand -hex 32
# Set it directly in Render's dashboard. NEVER commit it, and never put a real
# value in this file.
HOLDINGS_JWT_SECRET=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Market Data (ALL FREE — no API keys needed) ───────────────────────────────
# Yahoo Finance: used via unofficial yfinance-compatible endpoints (free, no key)
# Symbols: ^NSEI (Nifty50), ^NSEMDCP50 (Midcap), ^NSESML (Smallcap), ^INDIAVIX
# NSE India website scraping (public data, 15-second delay)
# Data latency: 15 seconds for indices, 1-min for stocks via Yahoo Finance
YAHOO_FINANCE_CACHE_TTL=15           # seconds to cache each quote
NSE_SCRAPE_INTERVAL=30000            # ms between NSE scrape cycles
SCAN_INTERVAL_MS=30000               # breakout scanner cycle
NEWS_INTERVAL_MS=120000              # news refresh cycle

# ── Optional: Upgrade to Paid Data (better latency) ──────────────────────────
# Zerodha Kite Connect: ₹2,000/mo — 100ms latency, full tick data
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=

# TrueData: ₹500-2000/mo — 1-second data, full NSE coverage
# TRUEDATA_USER=
# TRUEDATA_PASSWORD=

# Upstox API: Free with account — real-time WebSocket quotes
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
# UPSTOX_ACCESS_TOKEN=
